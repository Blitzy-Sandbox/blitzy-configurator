# =====================================================================
# StrikeForge / blitzy-configurator — Environment Variable Template
# ---------------------------------------------------------------------
# Every variable in this file MUST be populated before running the
# backend or the integration test suite.
#
# Rule R4 (NON-NEGOTIABLE):
#   - There are NO fallback values in source code.
#   - The backend exits non-zero within 2 seconds when any required
#     variable is unset.
#
# Usage:
#   cp .env.example .env  &&  fill in values
#   .env is gitignored; .env.example is the only committed template.
# =====================================================================

# ---------------------------------------------------------------------
# DATABASE_URL
#   Consumer: backend/src/db/pool.ts (pg.Pool configuration).
#   Cloud Run format:
#     postgres://postgres:<password>@/strikeforge?host=/cloudsql/<PROJECT>:<REGION>:<INSTANCE>
#   Local format (TCP):
#     postgres://postgres:postgres@127.0.0.1:5432/strikeforge
#   Per Rule C3, the connection config is constructed entirely from
#   this URL — no hard-coded host paths anywhere else in source.
# ---------------------------------------------------------------------
DATABASE_URL=

# ---------------------------------------------------------------------
# FIREBASE_PROJECT_ID
#   Consumer: backend/src/auth/firebase-admin.ts (Firebase Admin SDK).
#   Must match the emulator's configured project ID when using
#   LocalGCP (e.g., strikeforge-local).
#   In production, this is the real Firebase project ID.
# ---------------------------------------------------------------------
FIREBASE_PROJECT_ID=

# ---------------------------------------------------------------------
# GCS_BUCKET_NAME
#   Consumer: backend/src/services/gcs.service.ts.
#   Must match a bucket that exists in the target environment
#   (or is auto-created by fake-gcs-server locally).
#   Example: strikeforge-logos-local for local dev.
# ---------------------------------------------------------------------
GCS_BUCKET_NAME=

# ---------------------------------------------------------------------
# GCS_EMULATOR_HOST
#   Consumer: backend/src/services/gcs.service.ts.
#   Points @google-cloud/storage at fake-gcs-server instead of real
#   GCS for local dev / CI integration tests.
#   Local example: http://localhost:4443 (fake-gcs-server default).
#   In production: this variable MUST still be set (per Rule R4) —
#   set it to "disabled" or any placeholder; the production service
#   bypasses the emulator when GCP default credentials are active.
# ---------------------------------------------------------------------
GCS_EMULATOR_HOST=

# ---------------------------------------------------------------------
# COVERAGE_THRESHOLD
#   Consumer: backend/jest.config.unit.ts (coverage gate per ST-038).
#   Integer 0–100 representing the minimum required line coverage
#   for the unit-test gate.
#   Suggested value: 80
#   Per Rule R4, the variable must be set — Jest's threshold
#   evaluator fails when undefined.
# ---------------------------------------------------------------------
COVERAGE_THRESHOLD=

# ---------------------------------------------------------------------
# GCP_REGION
#   Consumer: Cloud Deploy CLI commands and Cloud Run deployment
#   (Gate MG2-G).
#   Example: us-central1
#   Must match the region configured in
#   delivery-pipeline/clouddeploy.yaml.
# ---------------------------------------------------------------------
GCP_REGION=
