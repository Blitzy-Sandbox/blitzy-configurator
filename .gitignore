# =====================================================================
# .gitignore for the StrikeForge / blitzy-configurator monorepo
# Authored per AAP §0.3.2 — Node / Docker / Playwright / coverage / build output
# =====================================================================

# ---------------------------------------------------------------------
# Node
# ---------------------------------------------------------------------
node_modules/
*/node_modules/
**/node_modules/
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*
.pnpm-store/
.npm/
# The monorepo uses a single hoisted package-lock.json at the repo root
# (per the npm workspaces layout authored in Phase A). The docker-compose
# backend service runs `npm install` inside the container with WORKDIR=/app
# bind-mounted from `backend/`, which generates a transient
# `backend/package-lock.json` on the host. That file MUST NOT be committed
# because npm would then resolve workspace dependencies twice (once from
# root, once from backend), defeating the hoisting. The same applies to
# `frontend/package-lock.json` if a similar bind-mount pattern is used.
backend/package-lock.json
frontend/package-lock.json

# ---------------------------------------------------------------------
# Environment files (NEVER commit real values; .env.example is the
# only template that is committed per Rule R4)
# ---------------------------------------------------------------------
.env
.env.local
.env.*.local
!.env.example

# ---------------------------------------------------------------------
# TypeScript build output
# ---------------------------------------------------------------------
dist/
*/dist/
**/dist/
build/
*/build/
**/build/
*.tsbuildinfo

# ---------------------------------------------------------------------
# Vite output (frontend)
# ---------------------------------------------------------------------
frontend/dist/
frontend/.vite/

# ---------------------------------------------------------------------
# Jest / coverage
# ---------------------------------------------------------------------
coverage/
*/coverage/
**/coverage/
*.lcov
.nyc_output/

# ---------------------------------------------------------------------
# Playwright
# ---------------------------------------------------------------------
playwright-report/
**/playwright-report/
test-results/
**/test-results/
blob-report/
**/blob-report/
playwright/.cache/

# ---------------------------------------------------------------------
# Visual regression diff artifacts
# (baselines under frontend/visual-baselines/ ARE committed per ST-046-AC4)
# ---------------------------------------------------------------------
**/test-results/**/*-diff.png
**/test-results/**/*-actual.png

# ---------------------------------------------------------------------
# OS / editor
# ---------------------------------------------------------------------
.DS_Store
Thumbs.db
.idea/
.vscode/
*.swp
*.swo

# ---------------------------------------------------------------------
# Docker / local dev
# ---------------------------------------------------------------------
.docker/
*.pid

# ---------------------------------------------------------------------
# Logs
# ---------------------------------------------------------------------
logs/
*.log

# ---------------------------------------------------------------------
# Firebase / GCP credentials (LocalGCP uses emulators; never commit
# real credentials)
# ---------------------------------------------------------------------
*-service-account.json
firebase-debug.log
firebase-debug.*.log
.firebase/
gcp-keyfile*.json
credentials.json
