{
  "name": "blitzy-configurator",
  "version": "0.1.0",
  "private": true,
  "description": "StrikeForge 3D sports ball configurator monorepo (backend + frontend + delivery pipeline)",
  "license": "UNLICENSED",
  "workspaces": [
    "backend",
    "frontend"
  ],
  "engines": {
    "node": ">=20.0.0 <21.0.0",
    "npm": ">=10.0.0"
  },
  "packageManager": "npm@10.8.2",
  "scripts": {
    "lint": "run-p lint:backend lint:frontend",
    "lint:backend": "npm --workspace backend run lint",
    "lint:frontend": "npm --workspace frontend run lint",
    "typecheck": "run-p typecheck:backend typecheck:frontend",
    "typecheck:backend": "npm --workspace backend run typecheck",
    "typecheck:frontend": "npm --workspace frontend run typecheck",
    "test": "run-s test:unit test:integration test:e2e",
    "test:unit": "npm --workspace backend run test:unit",
    "test:integration": "npm --workspace backend run test:integration",
    "test:e2e": "npm --workspace frontend run test:e2e",
    "test:visual": "npm --workspace frontend run test:visual",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "dev": "run-p dev:backend dev:frontend",
    "dev:backend": "npm --workspace backend run dev",
    "dev:frontend": "npm --workspace frontend run dev",
    "build": "run-s build:backend build:frontend",
    "build:backend": "npm --workspace backend run build",
    "build:frontend": "npm --workspace frontend run build",
    "migrate:up": "npm --workspace backend run migrate:up",
    "migrate:down": "npm --workspace backend run migrate:down"
  },
  "devDependencies": {
    "@typescript-eslint/eslint-plugin": "^6.21.0",
    "@typescript-eslint/parser": "^6.21.0",
    "eslint": "^8.57.0",
    "npm-run-all": "^4.1.5",
    "prettier": "^3.2.5",
    "typescript": "^5.4.0"
  }
}
