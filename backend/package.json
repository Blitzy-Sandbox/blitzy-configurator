{
  "name": "@strikeforge/backend",
  "version": "0.1.0",
  "private": true,
  "description": "StrikeForge backend API (Express + PostgreSQL + Firebase Admin + GCS) with full observability stack",
  "license": "UNLICENSED",
  "main": "dist/index.js",
  "engines": {
    "node": ">=20.0.0 <21.0.0",
    "npm": ">=10.0.0"
  },
  "scripts": {
    "build": "tsc",
    "start": "node dist/index.js",
    "dev": "ts-node-dev --respawn --transpile-only --exit-child src/index.ts",
    "typecheck": "tsc --noEmit",
    "lint": "eslint src/ tests/ jest.config.*.ts --max-warnings 0",
    "lint:fix": "eslint src/ tests/ jest.config.*.ts --fix",
    "test": "npm run test:unit && npm run test:integration",
    "test:unit": "jest --config jest.config.unit.ts",
    "test:unit:coverage": "jest --config jest.config.unit.ts --coverage",
    "test:integration": "jest --config jest.config.integration.ts --forceExit",
    "migrate:up": "node-pg-migrate up",
    "migrate:down": "node-pg-migrate down",
    "migrate:create": "node-pg-migrate create",
    "format": "prettier --write src/ tests/ migrations/ *.ts *.json",
    "format:check": "prettier --check src/ tests/ migrations/ *.ts *.json"
  },
  "node-pg-migrate": {
    "dir": "migrations",
    "migrations-table": "pgmigrations",
    "migrations-schema": "public",
    "check-order": true,
    "verbose": true
  },
  "dependencies": {
    "@google-cloud/storage": "^7.12.0",
    "@opentelemetry/api": "^1.8.0",
    "@opentelemetry/auto-instrumentations-node": "^0.47.0",
    "@opentelemetry/resources": "^1.25.0",
    "@opentelemetry/sdk-node": "^0.50.0",
    "@opentelemetry/semantic-conventions": "^1.25.0",
    "cors": "^2.8.6",
    "dotenv": "^16.4.5",
    "express": "^4.19.2",
    "firebase-admin": "^12.3.0",
    "node-pg-migrate": "^6.2.2",
    "pg": "^8.12.0",
    "pino": "^8.21.0",
    "pino-http": "^8.5.1",
    "prom-client": "^15.1.3",
    "uuid": "^9.0.1",
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "@types/cors": "^2.8.19",
    "@types/express": "^4.17.21",
    "@types/jest": "^29.5.12",
    "@types/node": "^20.14.11",
    "@types/pg": "^8.11.6",
    "@types/supertest": "^6.0.2",
    "@types/uuid": "^9.0.8",
    "@typescript-eslint/eslint-plugin": "^6.21.0",
    "@typescript-eslint/parser": "^6.21.0",
    "eslint": "^8.57.0",
    "jest": "^29.7.0",
    "jest-junit": "^16.0.0",
    "pino-pretty": "^11.2.2",
    "prettier": "^3.2.5",
    "supertest": "^6.3.4",
    "ts-jest": "^29.1.5",
    "ts-node-dev": "^2.0.0",
    "typescript": "^5.4.5"
  }
}
