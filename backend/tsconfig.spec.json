{
  "extends": "./tsconfig.json",
  "compilerOptions": {
    "noEmit": true,
    "rootDir": ".",
    "isolatedModules": false,
    "noUnusedLocals": false,
    "noUnusedParameters": false
  },
  "include": ["jest.config.unit.ts", "jest.config.integration.ts", "tests/**/*.ts"],
  "exclude": ["node_modules", "dist", "coverage", "migrations"]
}
